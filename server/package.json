{
  "name": "mental-health-buddy-server",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx src/index.ts",
    "dev:watch": "cross-env NODE_ENV=development tsx watch --exclude \"**/node_modules/.vite-temp/**\" --exclude \"**/node_modules/.vite/**\" src/index.ts",
    "build": "tsc",
    "start": "cross-env NODE_ENV=production node dist/index.js"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/helmet": "^12.0.1",
    "@fastify/middie": "^9.0.3",
    "@fastify/static": "^8.2.0",
    "@google/generative-ai": "^0.24.1",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^4.7.0",
    "cross-env": "^7.0.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
