PORT=8787
# Pino log level: fatal | error | warn | info | debug | trace | silent (default: info in production, debug in development).
# Startup-only lines (static SPA path, FX rate loaded) use `debug` so they stay out of GCP at default `info`.
# LOG_LEVEL=info

# Optional reference origin for split UI/API deployments.
# Production: set CORS_STRICT=true and match the browser origin exactly (e.g. https://yourapp.com).
FRONTEND_ORIGIN=http://localhost:8787

# --- HTTP / abuse (defaults are safe for local dev) ---
# Behind nginx / Cloudflare so X-Forwarded-For is trusted for client IP rate limiting:
# TRUST_PROXY=true
# Strict CORS in production only (NODE_ENV=production): only FRONTEND_ORIGIN + non-browser requests without Origin:
# CORS_STRICT=false
# Max JSON POST body bytes (default 524288 = 512 KiB):
# BODY_LIMIT_BYTES=524288
# Global Fastify request timeout ms; 0 or unset = no timeout (recommended for SSE streaming):
# REQUEST_TIMEOUT_MS=0
# Sliding window ms / max POST API calls per IP per window / max IPs tracked in memory:
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX_PER_WINDOW=40
# RATE_LIMIT_MAX_TRACKED_IPS=20000

# deepseek | gemini
CHAT_PROVIDER=deepseek

# --- DeepSeek (OpenAI-compatible) ---
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
# Optional: USD per 1M tokens — used for estimated cost in logs + last SSE frame (see provider pricing).
# DEEPSEEK_INPUT_USD_PER_1M=
# DEEPSEEK_OUTPUT_USD_PER_1M=

# --- Google Gemini ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
# GEMINI_INPUT_USD_PER_1M=
# GEMINI_OUTPUT_USD_PER_1M=

# Production (`cross-env NODE_ENV=production node dist/index.js`): run `npm run build` from the
# **repository root** first so `../dist/index.html` exists next to this server.
